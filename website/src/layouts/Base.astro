---
/**
 * Base-Layout — gemeinsame Hülle aller Seiten.
 * Enthält <head> mit SEO/GEO-Meta, Open Graph, Canonical, JSON-LD
 * (LocalBusiness/GeneralContractor) sowie Header + Footer.
 *
 * Props:
 *  - title:        Seitentitel (ohne Marken-Suffix)
 *  - description:  Meta-Description (~150–160 Zeichen)
 *  - canonicalPath:Pfad ab Domainwurzel, z. B. "/leistungen/industriebau"
 *  - image:        OG-Bild (absoluter Pfad ab Wurzel)
 *  - jsonLd:       optionales Array zusätzlicher JSON-LD-Objekte (Service, FAQ, Breadcrumb …)
 *  - noindex:      true → von Suchmaschinen ausschließen (z. B. Danke-Seiten)
 */
import '../styles/styles.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { company } from '../data/site';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  image?: string;
  jsonLd?: Record<string, any>[];
  noindex?: boolean;
  transparentHeader?: boolean;
}

const {
  title,
  description,
  canonicalPath = '/',
  image = '/img/industriebau.webp',
  jsonLd = [],
  noindex = false,
  transparentHeader = false,
} = Astro.props;

const siteName = 'Vonhoegen Bauunternehmung';
const fullTitle = title.includes(siteName) ? title : `${title} | ${siteName}`;
const canonical = new URL(canonicalPath, Astro.site).href;
const ogImage = new URL(image, Astro.site).href;

// Basis-LocalBusiness-Schema (auf jeder Seite). GEO/Local-SEO-Signal für
// Suchmaschinen und LLMs: Wer, Wo, Womit, Einzugsgebiet.
const localBusiness = {
  '@context': 'https://schema.org',
  '@type': 'GeneralContractor',
  '@id': `${Astro.site}#organization`,
  name: company.legalName,
  url: Astro.site?.href,
  email: company.email,
  telephone: company.phone,
  faxNumber: company.fax,
  image: ogImage,
  address: {
    '@type': 'PostalAddress',
    streetAddress: company.street,
    postalCode: company.postalCode,
    addressLocality: company.city,
    addressRegion: company.regionShort,
    addressCountry: company.country,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: company.geo.lat,
    longitude: company.geo.lng,
  },
  areaServed: company.serviceAreas.map((a) => ({ '@type': 'City', name: a })),
  knowsAbout: ['Industriebau', 'Pharmabau', 'Reinraumbau', 'Brandschutz', 'Schadstoffsanierung', 'Generalunternehmer'],
};

const schemas = [localBusiness, ...jsonLd];
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Aktiviert Scroll-Reveals nur bei aktivem JS (kein FOUC, kein Inhalt versteckt ohne JS) -->
    <script is:inline>document.documentElement.classList.add('reveal-ready');</script>
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="author" content={company.legalName} />
    <meta name="geo.region" content="DE-NW" />
    <meta name="geo.placename" content={`${company.city}, ${company.region}`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400..700;1,400..700&display=swap"
      rel="stylesheet"
    />

    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Structured data (JSON-LD) -->
    {schemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <slot name="head" />
  </head>
  <body>
    <Header transparent={transparentHeader} />
    <main id="top">
      <slot />
    </main>
    <Footer />
    <div class="grain" aria-hidden="true"></div>

    <!-- Cursor-folgendes Bild für Hover-Reveals (z. B. Leistungsumfang) -->
    <div class="cursor-img" aria-hidden="true"><div class="cursor-img-inner"><img alt="" decoding="async" /></div></div>

    <script>
      // Cursor-folgendes Bild beim Hover über [data-hover-img]
      (() => {
        const ci = document.querySelector('.cursor-img');
        if (!ci) return;
        const img = ci.querySelector('img');
        const canHover = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
        if (!canHover) return;
        let tx = 0, ty = 0, cx = 0, cy = 0, init = false, active = false, raf = null;
        window.addEventListener('pointermove', (e) => {
          tx = e.clientX; ty = e.clientY;
          if (!init) { cx = tx; cy = ty; init = true; }
        }, { passive: true });
        const loop = () => {
          cx += (tx - cx) * 0.18;
          cy += (ty - cy) * 0.18;
          ci.style.transform = `translate(${cx}px, ${cy}px)`;
          if (active) raf = requestAnimationFrame(loop);
        };
        document.querySelectorAll('[data-hover-img]').forEach((el) => {
          el.addEventListener('pointerenter', () => {
            const src = el.getAttribute('data-hover-img');
            if (!src) return;
            img.src = src;
            ci.classList.add('show');
            active = true;
            cancelAnimationFrame(raf);
            loop();
          });
          el.addEventListener('pointerleave', () => {
            ci.classList.remove('show');
            active = false;
          });
        });
      })();
    </script>

    <script>
      // Scroll-Reveals (Fade-up) + gestaffelte Gruppen — ohne Framework
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const targets = document.querySelectorAll('[data-reveal], [data-reveal-group]');
      if (reduce) {
        targets.forEach((el) => el.classList.add('in'));
      } else if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('in');
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
        );
        targets.forEach((el) => io.observe(el));
      } else {
        targets.forEach((el) => el.classList.add('in'));
      }

      // Count-up für Kennzahlen ([data-count]) beim Scrollen
      const counters = document.querySelectorAll('[data-count]');
      if (counters.length) {
        const fmt = (n) => n.toLocaleString('de-DE');
        const run = (el) => {
          const target = parseFloat(el.getAttribute('data-count')) || 0;
          if (reduce) { el.textContent = fmt(target); return; }
          const dur = 1600;
          const t0 = performance.now();
          const tick = (t) => {
            const p = Math.min(1, (t - t0) / dur);
            const eased = 1 - Math.pow(1 - p, 3);
            el.textContent = fmt(Math.round(target * eased));
            if (p < 1) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
        };
        if ('IntersectionObserver' in window) {
          const cio = new IntersectionObserver((entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) { run(e.target); cio.unobserve(e.target); }
            });
          }, { threshold: 0.5 });
          counters.forEach((el) => cio.observe(el));
        } else {
          counters.forEach(run);
        }
      }

      // Wort-für-Wort Farb-Reveal beim Scrollen (wie auf der Startseite)
      const wordBlocks = Array.from(document.querySelectorAll('[data-wordreveal]'));
      if (wordBlocks.length && !reduce) {
        const FROM = [156, 162, 161]; // --ink-faint
        const TO = [17, 19, 18]; // --ink
        const clamp = (v) => Math.max(0, Math.min(1, v));
        const mix = (p) =>
          `rgb(${FROM.map((f, i) => Math.round(f + (TO[i] - f) * p)).join(',')})`;
        wordBlocks.forEach((b) => {
          const text = b.textContent.trim();
          b.textContent = '';
          text.split(/\s+/).forEach((w) => {
            const s = document.createElement('span');
            s.textContent = w + ' ';
            s.style.color = mix(0);
            b.appendChild(s);
          });
        });
        let ticking = false;
        const update = () => {
          ticking = false;
          const vh = window.innerHeight;
          wordBlocks.forEach((b) => {
            const rect = b.getBoundingClientRect();
            const start = vh * 0.85, end = vh * 0.35;
            const p = clamp((start - rect.top) / (start - end));
            const spans = b.children;
            const n = spans.length;
            for (let i = 0; i < n; i++) {
              const ws = i / n, we = (i + 0.6) / n;
              const wp = clamp((p - ws) / (we - ws));
              spans[i].style.color = mix(wp);
            }
          });
        };
        const onScroll = () => {
          if (!ticking) { ticking = true; requestAnimationFrame(update); }
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        window.addEventListener('resize', onScroll, { passive: true });
        update();
      }
    </script>
  </body>
</html>
