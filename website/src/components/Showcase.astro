---
/**
 * Bild-Showcase für Leistungsseiten — zeigt fertige, moderne Gebäude/Projekte.
 * Erstes Bild groß (breit), darunter zwei kleinere. Reveal + Hover-Zoom.
 */
interface Shot { src: string; alt: string; caption?: string }
interface Props {
  eyebrow?: string;
  title: string;
  tail?: string;
  intro?: string;
  images: Shot[]; // erwartet 3 Bilder: [breit, klein, klein]
  variant?: 'grey' | 'default';
}
const { eyebrow = 'Referenzbilder', title, tail = '', intro, images, variant = 'default' } = Astro.props;
const [lead, ...rest] = images;
---
<section class:list={['section', { grey: variant === 'grey' }]}>
  <div class="wrap">
    <div class="section-head" data-reveal>
      {eyebrow && <span class="eyebrow">{eyebrow}</span>}
      <h2 class="tt" style="margin-top:1.2rem">{title} {tail && <span class="mute">{tail}</span>}</h2>
      {intro && <p style="margin-top:1.2rem;color:var(--ink-soft);max-width:60ch;line-height:1.6">{intro}</p>}
    </div>

    <figure class="showcase-lead" data-reveal>
      <div class="media"><img src={lead.src} alt={lead.alt} loading="lazy" decoding="async" /></div>
      {lead.caption && <figcaption>{lead.caption}</figcaption>}
    </figure>

    {rest.length > 0 && (
      <div class="showcase-row" data-reveal-group>
        {rest.map((s) => (
          <figure>
            <div class="media"><img src={s.src} alt={s.alt} loading="lazy" decoding="async" /></div>
            {s.caption && <figcaption>{s.caption}</figcaption>}
          </figure>
        ))}
      </div>
    )}
  </div>
</section>
