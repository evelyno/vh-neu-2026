---
/**
 * Einblicke — horizontales Carousel mit Karten (Bild + Caption).
 * Touch-Swipe (nativ), Trackpad, Drag-to-scroll (Desktop) und ein stilischer
 * Fortschritts-Scrollbalken (container-breit). Scoped JS pro Instanz.
 */
interface Shot { src: string; alt: string; caption?: string; tag?: string }
interface Props {
  eyebrow?: string;
  title: string;
  tail?: string;
  intro?: string;
  images: Shot[];
  variant?: 'grey' | 'default';
}
const { eyebrow = 'Einblicke', title, tail = '', intro, images, variant = 'default' } = Astro.props;
---
<section class:list={['section', 'showcase', { grey: variant === 'grey' }]}>
  <div class="wrap">
    <div class="showcase-head" data-reveal>
      <div>
        {eyebrow && <span class="eyebrow">{eyebrow}</span>}
        <h2 class="tt" style="margin-top:1.2rem">{title} {tail && <span class="mute">{tail}</span>}</h2>
      </div>
      {intro && <p class="showcase-intro">{intro}</p>}
    </div>
  </div>

  <div class="showcase-carousel" data-reveal>
    <div class="showcase-track">
      {images.map((s) => (
        <figure class="showcase-card">
          <div class="media"><img src={s.src} alt={s.alt} loading="lazy" decoding="async" /></div>
          <figcaption>
            {s.tag && <span class="sc-tag">{s.tag}</span>}
            {s.caption && <span class="sc-cap">{s.caption}</span>}
          </figcaption>
        </figure>
      ))}
    </div>
  </div>

  <div class="wrap">
    <div class="showcase-progress" role="presentation"><span class="showcase-progress-thumb"></span></div>
  </div>
</section>

<script>
  document.querySelectorAll('.showcase').forEach((root) => {
    const track = root.querySelector('.showcase-carousel');
    const thumb = root.querySelector('.showcase-progress-thumb');
    const bar = root.querySelector('.showcase-progress');
    if (!track || !thumb || !bar) return;

    const update = () => {
      const max = track.scrollWidth - track.clientWidth;
      const ratio = track.clientWidth / track.scrollWidth;
      const w = Math.max(0.12, Math.min(1, ratio));
      thumb.style.width = w * 100 + '%';
      const p = max > 0 ? track.scrollLeft / max : 0;
      thumb.style.transform = `translateX(${p * (bar.clientWidth - thumb.clientWidth)}px)`;
    };
    update();
    track.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update, { passive: true });

    // Sanft zur nächstgelegenen Karte einrasten
    const snapToNearest = () => {
      const cards = track.querySelectorAll('.showcase-card');
      const edge = parseFloat(getComputedStyle(track).scrollPaddingLeft) || 0;
      const base = track.getBoundingClientRect().left;
      let bestLeft = track.scrollLeft, bestDist = Infinity;
      cards.forEach((c) => {
        const delta = c.getBoundingClientRect().left - base - edge;
        const target = track.scrollLeft + delta;
        if (Math.abs(delta) < bestDist) { bestDist = Math.abs(delta); bestLeft = target; }
      });
      track.scrollTo({ left: bestLeft, behavior: 'smooth' });
    };

    // Drag-to-scroll auf den Karten (Desktop, feine Maus)
    if (window.matchMedia('(hover: hover) and (pointer: fine)').matches) {
      let down = false, moved = false, startX = 0, startScroll = 0;
      track.addEventListener('pointerdown', (e) => {
        down = true; moved = false; startX = e.clientX; startScroll = track.scrollLeft;
        track.classList.add('dragging');
      });
      window.addEventListener('pointerup', () => {
        if (!down) return;
        down = false; track.classList.remove('dragging');
        if (moved) snapToNearest();
      });
      window.addEventListener('pointermove', (e) => {
        if (!down) return;
        if (Math.abs(e.clientX - startX) > 3) moved = true;
        track.scrollLeft = startScroll - (e.clientX - startX);
      });
    }

    // Klick/Drag auf den Fortschrittsbalken
    const seek = (clientX) => {
      const rect = bar.getBoundingClientRect();
      const p = Math.max(0, Math.min(1, (clientX - rect.left) / rect.width));
      track.scrollLeft = p * (track.scrollWidth - track.clientWidth);
    };
    let barDown = false;
    bar.addEventListener('pointerdown', (e) => { barDown = true; seek(e.clientX); });
    window.addEventListener('pointerup', () => { barDown = false; });
    window.addEventListener('pointermove', (e) => { if (barDown) seek(e.clientX); });
  });
</script>
