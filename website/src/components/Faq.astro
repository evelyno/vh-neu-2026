---
/**
 * FAQ-Accordion auf Basis nativer <details> (kein JS, voll zugänglich, SEO-stark).
 * Die passende FAQPage-JSON-LD wird in der jeweiligen Seite über buildFaqSchema() gesetzt.
 */
interface QA { q: string; a: string }
interface Props { items: QA[]; title?: string; tail?: string }
const { items, title = 'Häufige', tail = 'Fragen.' } = Astro.props;
---
<section class="section" id="faq">
  <div class="wrap">
    <div class="faq-head">
      <h2 class="tt">{title} <span class="mute">{tail}</span></h2>
    </div>
    <div class="faq" style="margin-top:clamp(40px,5vw,64px)">
      {items.map((item) => (
        <details class="faq-item">
          <summary class="faq-q">
            <span class="faq-num" aria-hidden="true"></span>
            <span class="faq-qt">{item.q}</span>
            <span class="pm" aria-hidden="true"></span>
          </summary>
          <div class="faq-a"><div class="faq-a-inner"><p set:html={item.a}></p></div></div>
        </details>
      ))}
    </div>
  </div>
</section>

<script>
  /* Akkordeon: smooth aus-/einklappen, immer nur ein Eintrag offen.
     <details> bleibt als No-JS-/SEO-Fallback erhalten; bei aktivem JS
     steuern wir die Höhe per Klasse (CSS grid-template-rows-Transition). */
  document.querySelectorAll<HTMLElement>('.faq').forEach((group) => {
    const items = Array.from(group.querySelectorAll<HTMLDetailsElement>('details.faq-item'));

    const close = (d: HTMLDetailsElement) => {
      d.classList.remove('is-open');
      const a = d.querySelector<HTMLElement>('.faq-a');
      if (!d.open) return;
      const done = (e: TransitionEvent) => {
        if (e.propertyName !== 'grid-template-rows') return;
        if (!d.classList.contains('is-open')) d.open = false;
        a?.removeEventListener('transitionend', done);
      };
      a?.addEventListener('transitionend', done);
    };

    const open = (d: HTMLDetailsElement) => {
      d.open = true;
      const a = d.querySelector<HTMLElement>('.faq-a');
      void a?.offsetHeight; // Reflow erzwingen, damit 0fr -> 1fr animiert
      d.classList.add('is-open');
    };

    items.forEach((d) => {
      const summary = d.querySelector('summary');
      summary?.addEventListener('click', (e) => {
        e.preventDefault();
        const wasOpen = d.classList.contains('is-open');
        items.forEach((other) => other !== d && close(other));
        wasOpen ? close(d) : open(d);
      });
    });
  });
</script>
