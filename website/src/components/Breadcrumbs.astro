---
/** Sichtbare Breadcrumb-Navigation. JSON-LD wird separat in der Seite gesetzt. */
interface Crumb { label: string; href: string }
interface Props { items: Crumb[] }
const { items } = Astro.props;
---
<nav class="breadcrumbs" aria-label="Brotkrümelnavigation">
  <ol>
    {items.map((c, i) => (
      <li>
        {i < items.length - 1 ? <a href={c.href}>{c.label}</a> : <span aria-current="page">{c.label}</span>}
        {i < items.length - 1 && <span class="sep" aria-hidden="true">/</span>}
      </li>
    ))}
  </ol>
</nav>
