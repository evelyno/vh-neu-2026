---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import Faq from '../../components/Faq.astro';
import CtaSection from '../../components/CtaSection.astro';
import Reviews from '../../components/Reviews.astro';
import { faqSchema, breadcrumbSchema, serviceSchema } from '../../lib/schema';

const path = '/leistungen/pharmabau';
const title = 'Pharmabau & Reinraumbau Aachen — GMP-konform | Vonhoegen';
const description =
  'Pharma- und Reinraumbau aus Würselen bei Aachen: GMP- und FDA-konforme Produktions- und Laborflächen, validierbar geplant und revisionssicher dokumentiert. Auch im laufenden Betrieb — im Rheinland, Düsseldorf & Köln.';

const breadcrumbs = [
  { label: 'Startseite', href: '/' },
  { label: 'Leistungen', href: '/leistungen' },
  { label: 'Pharmabau', href: path },
];

const scope = [
  { t: 'Reinraumbau', d: 'Reinräume nach Reinraumklassen (ISO 14644 / GMP A–D) — Wand-, Decken- und Bodensysteme inklusive Schleusenkonzept.', img: '/img/pharma.webp' },
  { t: 'GMP-Produktionsflächen', d: 'Produktions- und Abfüllbereiche, geplant für Validierung, Qualifizierung und behördliche Abnahme.', img: '/img/projekt-pharma.webp' },
  { t: 'Labor- & Technikbau', d: 'Labore, Technikzentralen und Mediensysteme — sauber getrennt, wartungsfreundlich und dokumentiert.', img: '/img/pharma.webp' },
  { t: 'Bau im laufenden Betrieb', d: 'Erweiterung und Umbau bei laufender Produktion — mit Abschottung, Hygiene- und Sicherheitskonzept.', img: '/img/projekt-pharma.webp' },
  { t: 'Qualifizierungs-Doku', d: 'Revisionssichere Dokumentation als Basis für IQ/OQ — nachvollziehbar für Audits und Behörden.', img: '/img/pharma.webp' },
  { t: 'Schlüsselfertig (GU)', d: 'Bau, Technik und Reinraumausbau aus einer Hand — ein Ansprechpartner, ein Festpreis.', img: '/img/projekt-pharma.webp' },
];

const faqs = [
  { q: 'Bauen Sie GMP- und FDA-konform?', a: 'Ja. Wir planen und errichten Produktions- und Reinraumbereiche so, dass sie GMP-Anforderungen erfüllen und qualifizier- bzw. validierbar sind — inklusive revisionssicherer Dokumentation.' },
  { q: 'Welche Reinraumklassen realisieren Sie?', a: 'Wir setzen Reinräume entsprechend ISO 14644 und GMP-Klassen A–D um. Die konkrete Auslegung stimmen wir auf Ihr Produkt und Ihren Prozess ab.' },
  { q: 'Können Sie im laufenden Betrieb erweitern?', a: 'Ja, das ist im Pharmaumfeld unser Standardfall: Wir arbeiten in Bauabschnitten mit klaren Abschottungs-, Hygiene- und Sicherheitskonzepten, damit Ihre Produktion weiterläuft.' },
  { q: 'In welcher Region sind Sie tätig?', a: 'Schwerpunkt ist Würselen, Aachen und die Städteregion. Pharmabau-Projekte realisieren wir darüber hinaus überregional im Rheinland, u.&nbsp;a. in Düsseldorf und Köln.' },
];

const jsonLd = [
  breadcrumbSchema(breadcrumbs),
  serviceSchema({ name: 'Pharmabau & Reinraumbau', serviceType: 'Pharmabau, Reinraumbau', description, url: path }),
  faqSchema(faqs),
];
---

<Base title={title} description={description} canonicalPath={path} image="/img/pharma.webp" jsonLd={jsonLd}>
  <PageHero
    eyebrow="Leistung · Pharmabau"
    title="Pharma- & Reinraumbau —<br />GMP-konform aus Würselen"
    subtitle="Reinräume, GMP-Produktionsflächen und Labore — validierbar geplant, revisionssicher dokumentiert und auf Wunsch im laufenden Betrieb realisiert."
    image="/img/pharma.webp"
    breadcrumbs={breadcrumbs}
  />

  <section class="section">
    <div class="wrap narrow">
      <span class="eyebrow" data-reveal>Pharmabau vom Generalunternehmer</span>
      <p class="statement" style="margin-top:1.6rem" data-wordreveal>
        Wir bauen Reinräume und GMP-Produktionsflächen in Aachen, Würselen und dem Rheinland — validierbar geplant und revisionssicher dokumentiert.
      </p>
      <p class="lead-text" data-reveal>
        Von der Reinraumzelle bis zur kompletten GMP-Produktion: Wir planen für Validierung und Behördenabnahme
        und bauen auf Wunsch bei laufender Produktion — alles aus einer Hand, mit <strong>Festpreis</strong> und
        <strong>festem Ansprechpartner</strong>.
      </p>
    </div>
  </section>

  <section class="section grey">
    <div class="wrap">
      <div class="section-head" data-reveal>
        <span class="eyebrow">Leistungsumfang</span>
        <h2 class="tt">Was wir im Pharmabau <span class="mute">umsetzen.</span></h2>
      </div>
      <div class="feature-grid" data-reveal-group>
        {scope.map((s) => (
          <article class="feature-card" data-hover-img={s.img}><h3>{s.t}</h3><p>{s.d}</p></article>
        ))}
      </div>
    </div>
  </section>

  <Reviews
    items={[
      { quote: 'Der Reinraum wurde im laufenden Betrieb erweitert, sauber dokumentiert und GMP-konform übergeben. Wir wurden in jeder Phase mitgenommen.', name: 'Dr. S. Keller', role: 'Werkleitung, Pharma · Aachen' },
      { quote: 'Validierbar geplant, revisionssicher dokumentiert — die Behördenabnahme verlief ohne Beanstandung.', name: 'A. Vogt', role: 'Qualifizierung · Rheinland' },
      { quote: 'Saubere Schnittstellen zwischen Bau, Technik und Reinraumausbau. Ein Ansprechpartner für alles.', name: 'M. Lindner', role: 'Projektleitung · Köln' },
    ]}
    eyebrow="Referenzen & Stimmen"
    title="Pharmabau, der"
    tail="Audits besteht."
    variant="grey"
  />

  <Faq items={faqs} title="Pharmabau —" tail="häufige Fragen." />
  <CtaSection
    heading="Reinraum oder GMP-Fläche geplant?"
    lead="Schildern Sie uns Ihr Vorhaben — wir melden uns innerhalb von 48 Stunden mit einer ehrlichen Ersteinschätzung."
    image="/img/pharma.webp"
  />
</Base>
