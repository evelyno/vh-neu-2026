---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import Faq from '../../components/Faq.astro';
import CtaSection from '../../components/CtaSection.astro';
import Showcase from '../../components/Showcase.astro';
import Reviews from '../../components/Reviews.astro';
import Stats from '../../components/Stats.astro';
import { faqSchema, breadcrumbSchema, serviceSchema } from '../../lib/schema';

const path = '/leistungen/industriebau';
const title = 'Industriebau Aachen & Würselen — Produktions- & Logistikhallen schlüsselfertig';
const description =
  'Industriebau aus Würselen bei Aachen: Produktions-, Logistik- und Gewerbehallen schlüsselfertig vom Generalunternehmer. Festpreis, terminsicher, statisch durchdacht — auch in Düsseldorf, Köln & dem Rheinland.';

const breadcrumbs = [
  { label: 'Startseite', href: '/' },
  { label: 'Leistungen', href: '/leistungen' },
  { label: 'Industriebau', href: path },
];

// Leistungsumfang — keyword-orientiert
const scope = [
  { t: 'Produktionshallen', d: 'Hallen für Fertigung und Montage — mit tragfähigen Böden, Kranbahnen und auf Ihre Prozesse abgestimmter Statik.', img: '/img/industriebau-halle.webp' },
  { t: 'Logistik- & Lagerhallen', d: 'Hochregal-, Kommissionier- und Umschlagflächen mit Rampen, Toren und effizienten Verkehrswegen.', img: '/img/industriebau-luftbild.webp' },
  { t: 'Gewerbe- & Mehrzweckhallen', d: 'Flexible Gewerbebauten mit integrierten Büro-, Sozial- und Ausstellungsflächen.', img: '/img/industriebau-gebaeude.webp' },
  { t: 'Hallenerweiterung & Umbau', d: 'Anbauten und Aufstockungen — geplant für den Bau im laufenden Betrieb, ohne Ihre Produktion zu stoppen.', img: '/img/industriebau-detail.webp' },
  { t: 'Stahl- & Massivbau', d: 'Stahl-, Beton- oder Hybridkonstruktion — wir wählen das System, das zu Spannweite, Nutzung und Budget passt.', img: '/img/industriebau-hero.webp' },
  { t: 'Schlüsselfertigbau (GU)', d: 'Von Gründung bis Übergabe alles aus einer Hand — ein Generalunternehmer, ein Festpreis, ein Ansprechpartner.', img: '/img/projekt-halle.webp' },
];

const steps = [
  ['01', 'Bedarf & Standort', 'Wir analysieren Nutzung, Prozesse, Grundstück und Genehmigungslage — und übersetzen sie in ein tragfähiges Baukonzept.'],
  ['02', 'Planung & Festpreis', 'Sie erhalten Entwurf, Statikkonzept, verbindlichen Festpreis und Terminplan. Klar kalkuliert, kein Blindflug.'],
  ['03', 'Rohbau & Ausbau', 'Eigene Fachkräfte und geprüfte Partner setzen termintreu um — von Fundament und Tragwerk bis Technik und Fassade.'],
  ['04', 'Übergabe & Service', 'Schlüsselfertige Übergabe mit vollständiger Dokumentation — und ein Ansprechpartner, der danach erreichbar bleibt.'],
];

const benefits = [
  ['Fester Ansprechpartner', 'Ein Projektleiter von der ersten Skizze bis zur Schlüsselübergabe — keine anonymen Subunternehmer-Ketten.'],
  ['Festpreis & Termintreue', 'Verbindliche Kalkulation und realistischer Terminplan. Was wir zusagen, halten wir.'],
  ['Bau im laufenden Betrieb', 'Erweiterungen und Umbauten mit durchdachten Abschnitts- und Sicherheitskonzepten — Ihre Produktion läuft weiter.'],
  ['Regionale Nähe', 'Kurze Wege aus Würselen in die Städteregion Aachen und das Rheinland — schnell vor Ort, wenn es zählt.'],
];

const faqs = [
  {
    q: 'Was kostet der Bau einer Industrie- oder Produktionshalle?',
    a: 'Der Quadratmeterpreis hängt von Hallentyp, Spannweite, Ausstattung (z.&nbsp;B. Kranbahn, Bürotrakt, Tore) und Bodenlast ab. Nach einem kurzen Gespräch und einer Standortbetrachtung erhalten Sie von uns eine belastbare Kostenschätzung und anschließend einen verbindlichen Festpreis.',
  },
  {
    q: 'Wie lange dauert der Bau einer schlüsselfertigen Halle?',
    a: 'Je nach Größe und Genehmigungslage liegt die reine Bauzeit typischerweise zwischen wenigen und mehreren Monaten. Im ersten Termin nennen wir Ihnen einen realistischen Terminplan inklusive Genehmigungsphase.',
  },
  {
    q: 'Bauen Sie schlüsselfertig als Generalunternehmer?',
    a: 'Ja. Als Generalunternehmer übernehmen wir Planung, Rohbau, Ausbau und Haustechnik aus einer Hand — Sie haben einen Vertrag, einen Festpreis und einen Ansprechpartner.',
  },
  {
    q: 'Können Sie unsere Halle im laufenden Betrieb erweitern?',
    a: 'Ja. Gerade Erweiterungen und Aufstockungen planen wir in Bauabschnitten mit klaren Abschottungs- und Sicherheitskonzepten, damit Ihr Betrieb möglichst ungestört weiterläuft.',
  },
  {
    q: 'In welchen Regionen realisieren Sie Industriebau-Projekte?',
    a: 'Unser Schwerpunkt liegt in Würselen, Aachen und der gesamten Städteregion. Darüber hinaus realisieren wir Projekte überregional im Rheinland — unter anderem in Düsseldorf und Köln.',
  },
];

const reviews = [
  { quote: 'Vonhoegen hat unsere Produktionshalle termingenau und ohne eine einzige böse Überraschung übergeben. Ein fester Ansprechpartner, der wirklich zuhört.', name: 'M. Brandt', role: 'Geschäftsführer, Logistik · Eschweiler' },
  { quote: 'Ehrlicher Festpreis, verbindlicher Terminplan, eigene Fachkräfte. Was zugesagt wurde, wurde gehalten — wir würden jederzeit wieder beauftragen.', name: 'T. Möller', role: 'Bauherr, Gewerbebau · Aachen' },
  { quote: 'Die Hallenerweiterung lief im laufenden Betrieb reibungslos. Saubere Planung, klare Kommunikation, top Ergebnis.', name: 'R. Schäfer', role: 'Werkleitung, Produktion · Düren' },
];

const jsonLd = [
  breadcrumbSchema(breadcrumbs),
  serviceSchema({
    name: 'Industriebau',
    serviceType: 'Industriebau & Hallenbau',
    description,
    url: path,
  }),
  faqSchema(faqs),
];
---

<Base title={title} description={description} canonicalPath={path} image="/img/industriebau-hero.webp" jsonLd={jsonLd}>
  <PageHero
    eyebrow="Leistung · Industriebau"
    title="Industriebau in Aachen,<br />Würselen & dem Rheinland"
    subtitle="Produktions-, Logistik- und Gewerbehallen — schlüsselfertig geplant und gebaut. Terminsicher, statisch durchdacht und auf Ihren Betriebsablauf zugeschnitten."
    image="/img/industriebau-hero.webp"
    breadcrumbs={breadcrumbs}
  />

  <!-- Intro / GEO-Kurzantwort mit Wort-Reveal -->
  <section class="section">
    <div class="wrap narrow">
      <span class="eyebrow" data-reveal>Industriebau vom Generalunternehmer</span>
      <p class="statement" style="margin-top:1.6rem" data-wordreveal>
        Wir realisieren Industriebau in Würselen, Aachen und dem Rheinland — von der Produktionshalle bis zur schlüsselfertigen Gewerbeimmobilie.
      </p>
      <p class="lead-text" data-reveal>
        Als Generalunternehmer verantworten wir Planung, Rohbau, Ausbau und Haustechnik aus einer Hand:
        mit <strong>Festpreis</strong>, <strong>verbindlichem Terminplan</strong> und einem <strong>festen Ansprechpartner</strong>.
        So entsteht ein Gebäude, das zu Ihren Prozessen passt — und auch in zwanzig Jahren noch trägt, was wir heute versprechen.
      </p>
    </div>
  </section>

  <!-- Leistungsumfang -->
  <section class="section grey">
    <div class="wrap">
      <div class="section-head" data-reveal>
        <span class="eyebrow">Leistungsumfang</span>
        <h2 class="tt">Was wir im Industriebau <span class="mute">für Sie umsetzen.</span></h2>
      </div>
      <div class="feature-grid" data-reveal-group>
        {scope.map((s) => (
          <article class="feature-card" data-hover-img={s.img}>
            <h3>{s.t}</h3>
            <p>{s.d}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Showcase: fertige, moderne Gebäude -->
  <Showcase
    eyebrow="Einblicke"
    title="So sieht Industriebau"
    tail="von Vonhoegen aus."
    intro="Von der Stahlkonstruktion bis zur schlüsselfertigen Übergabe — ein Eindruck moderner Produktions-, Logistik- und Gewerbebauten."
    images={[
      { src: '/img/industriebau-gebaeude.webp', alt: 'Fertiggestelltes modernes Gewerbe- und Industriegebäude mit Glas- und Metallfassade in der Dämmerung', caption: 'Schlüsselfertiges Gewerbegebäude mit Büro- und Produktionstrakt' },
      { src: '/img/industriebau-halle.webp', alt: 'Moderne, helle Produktionshalle mit poliertem Betonboden und hoher Stahlkonstruktion', caption: 'Produktionshalle — hell, hoch und prozessgerecht' },
      { src: '/img/industriebau-luftbild.webp', alt: 'Luftaufnahme eines modernen Logistik- und Lagerkomplexes mit Ladezonen und Photovoltaik', caption: 'Logistikkomplex mit Ladezonen und Photovoltaik' },
    ]}
  />

  <!-- Detail-Bild + Vorteile -->
  <section class="section">
    <div class="wrap">
      <div class="split" data-reveal>
        <div class="media"><img src="/img/industriebau-detail.webp" alt="Tragwerk einer modernen Industriehalle im Bau — Stahlkonstruktion mit Oberlichtern" loading="lazy" decoding="async" /></div>
        <div>
          <span class="eyebrow">Ihr Vorteil</span>
          <h2 class="tt" style="margin-top:1.2rem">Warum Bauherren im Industriebau <span class="mute">auf Vonhoegen setzen.</span></h2>
          <div class="benefit-list" data-reveal-group>
            {benefits.map(([h, p]) => (
              <div class="benefit">
                <span class="ck">✓</span>
                <div><h3>{h}</h3><p>{p}</p></div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Kennzahlen -->
  <Stats
    variant="dark"
    items={[
      { value: 35, suffix: '+', label: 'Jahre Erfahrung im Bauwesen' },
      { value: 250, suffix: '+', label: 'realisierte Bauprojekte' },
      { value: 180000, suffix: ' m²', label: 'gebaute Fläche' },
      { value: 100, suffix: ' %', label: 'fester Ansprechpartner' },
    ]}
    note="Beispielhafte Kennzahlen — werden nach Freigabe durch die echten Werte des Unternehmens ersetzt."
  />

  <!-- Ablauf -->
  <section class="section grey">
    <div class="wrap">
      <div class="section-head" data-reveal>
        <span class="eyebrow">Ablauf</span>
        <h2 class="tt">Von der Idee zur Halle — <span class="mute">in vier Schritten.</span></h2>
      </div>
      <div class="steps steps-4" data-reveal-group>
        {steps.map(([n, h, p]) => (
          <div class="step"><div class="no">{n}</div><div><h3>{h}</h3><p>{p}</p></div></div>
        ))}
      </div>
    </div>
  </section>

  <!-- Einsatzgebiet / Local SEO -->
  <section class="section">
    <div class="wrap">
      <div class="area-layout">
        <div class="area-intro" data-reveal>
          <span class="eyebrow">Einsatzgebiet</span>
          <h2 class="tt" style="margin-top:1.2rem">Ihr Industriebau-Partner in <span class="mute">Aachen, NRW & dem Rheinland.</span></h2>
          <p class="lead-text" style="margin-top:1.4rem">
            Von unserem Standort in Würselen sind wir schnell in der gesamten <strong>Städteregion Aachen</strong> vor Ort —
            und realisieren Industrie- und Hallenbauprojekte ebenso im weiteren Rheinland, von Düsseldorf bis Köln.
          </p>
        </div>
        <ul class="area-tags" data-reveal>
          <li>Würselen</li><li>Aachen</li><li>Städteregion Aachen</li><li>Eschweiler</li>
          <li>Stolberg</li><li>Herzogenrath</li><li>Alsdorf</li><li>Baesweiler</li>
          <li>Düren</li><li>Jülich</li><li>Düsseldorf</li><li>Köln</li>
          <li>Mönchengladbach</li><li>Neuss</li><li>Leverkusen</li><li>Rheinland</li>
        </ul>
      </div>
    </div>
  </section>

  <Reviews
    items={reviews}
    eyebrow="Referenzen & Stimmen"
    title="Industriebau, der"
    tail="überzeugt."
    variant="grey"
  />

  <Faq items={faqs} title="Industriebau —" tail="häufige Fragen." />

  <CtaSection
    heading="Sie planen eine Halle?<br />Lassen Sie uns starten."
    lead="Schildern Sie uns kurz Standort, Nutzung und ungefähre Größe. Sie erhalten innerhalb von 48 Stunden eine ehrliche Ersteinschätzung — unverbindlich."
    image="/img/industriebau-hero.webp"
  />
</Base>
