---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import Faq from '../../components/Faq.astro';
import CtaSection from '../../components/CtaSection.astro';
import Showcase from '../../components/Showcase.astro';
import Reviews from '../../components/Reviews.astro';
import Stats from '../../components/Stats.astro';
import Industries from '../../components/Industries.astro';
import Certifications from '../../components/Certifications.astro';
import Comparison from '../../components/Comparison.astro';
import RelatedServices from '../../components/RelatedServices.astro';
import { faqSchema, breadcrumbSchema, serviceSchema } from '../../lib/schema';

const path = '/leistungen/sanierung';
const title = 'Sanierung & Schadstoffsanierung Aachen — TRGS 519 | Vonhoegen';
const description =
  'Sanierung & Schadstoffsanierung aus Würselen bei Aachen: Asbest- und Schadstoffrückbau nach TRGS 519, energetische Revitalisierung und Bestandssanierung — sicher, dokumentiert und freigegeben. Im Rheinland, Düsseldorf & Köln.';

const breadcrumbs = [
  { label: 'Startseite', href: '/' },
  { label: 'Leistungen', href: '/leistungen' },
  { label: 'Sanierung', href: path },
];

const scope = [
  { t: 'Schadstoffsanierung (TRGS 519)', d: 'Fachgerechter Rückbau asbesthaltiger und schadstoffbelasteter Bauteile — sicher für Mensch und Umwelt.' },
  { t: 'Rückbau & Entkernung', d: 'Kontrollierter Rückbau und Entkernung als Basis für Neubau, Umnutzung oder Revitalisierung.' },
  { t: 'Energetische Sanierung', d: 'Dämmung, Hülle und Technik auf aktuellen Stand bringen — für niedrigere Betriebskosten und Werterhalt.' },
  { t: 'Bestandssanierung', d: 'Instandsetzung und Modernisierung von Gewerbe- und Industriegebäuden im laufenden Betrieb.' },
  { t: 'Entsorgung & Nachweis', d: 'Ordnungsgemäße Entsorgung mit lückenlosem Nachweis — revisionssicher dokumentiert.' },
  { t: 'Freimessung & Freigabe', d: 'Begleitung bis zur Freimessung und Freigabe durch die zuständigen Stellen.' },
];

const steps = [
  ['01', 'Erfassung & Schadstoffcheck', 'Wir erfassen Objekt, Bausubstanz und Schadstoffe — und leiten das sichere Vorgehen ab.'],
  ['02', 'Konzept & Festpreis', 'Sie erhalten Sanierungs-, Abschottungs- und Entsorgungskonzept mit verbindlichem Festpreis und Terminplan.'],
  ['03', 'Sichere Ausführung', 'Rückbau und Schadstoffsanierung nach TRGS 519 — sicher abgeschottet, auf Wunsch im laufenden Betrieb.'],
  ['04', 'Freimessung & Freigabe', 'Ordnungsgemäße Entsorgung, lückenloser Nachweis und Begleitung bis zur Freimessung und Freigabe.'],
];

const benefits = [
  ['Sicher nach TRGS 519', 'Schadstoff- und Asbestsanierung fachgerecht nach TRGS 519 — mit Sicherheits-, Abschottungs- und Entsorgungskonzept.'],
  ['Im laufenden Betrieb', 'Sanierung in Abschnitten mit Staub- und Sicherheitskonzept — Ihr Betrieb läuft weiter.'],
  ['Lückenloser Nachweis', 'Ordnungsgemäße Entsorgung mit revisionssicherer Dokumentation bis zur Freimessung und Freigabe.'],
  ['Alles aus einer Hand', 'Rückbau, Sanierung und Wiederaufbau aus einer Hand — ein Ansprechpartner, ein Festpreis.'],
];

const faqs = [
  { q: 'Welche Sanierungsarbeiten übernehmen Sie?', a: 'Wir übernehmen Sanierungsarbeiten an Bestandsgebäuden, darunter Instandsetzungen, Rückbauarbeiten, Betonsanierung, Mauerwerksarbeiten, Abdichtungen, bauliche Anpassungen sowie vorbereitende Maßnahmen für weitere Gewerke.' },
  { q: 'Was muss ich tun, wenn Asbest vermutet wird?', a: 'Bei Verdacht auf Asbest sollte das Material nicht beschädigt, gebohrt, geschliffen oder eigenständig entfernt werden. Sinnvoll ist zunächst eine fachkundige Einschätzung bzw. Analyse, bevor weitere Maßnahmen geplant werden.' },
  { q: 'Übernehmen Sie auch Arbeiten im Zusammenhang mit Asbest?', a: 'Ja, wir unterstützen bei Sanierungs- und Rückbaumaßnahmen im Zusammenhang mit asbesthaltigen Baustoffen unter Einhaltung der geltenden Sicherheits- und Schutzmaßnahmen. Der konkrete Ablauf hängt vom jeweiligen Befund und Projektumfang ab.' },
  { q: 'Woran erkennt man mögliche Asbestbaustoffe?', a: 'Asbest kann in älteren Gebäuden unter anderem in Fassadenplatten, Bodenbelägen, Klebern, Spachtelmassen, Dacheindeckungen, Rohrisolierungen oder Brandschutzbauteilen vorkommen. Eine sichere Einschätzung ist jedoch nur durch Prüfung bzw. Analyse möglich.' },
  { q: 'Kann während einer Sanierung weitergearbeitet oder gewohnt werden?', a: 'Das hängt vom Umfang der Arbeiten, den betroffenen Bereichen und möglichen Schadstoffen ab. Bei sensiblen Sanierungen werden Schutzbereiche, Zugänge, Staubschutz und zeitliche Abläufe vorab genau geplant.' },
  { q: 'Wie läuft eine Sanierung mit Ihnen ab?', a: 'Zunächst besichtigen wir das Objekt und klären den Sanierungsbedarf. Danach werden Umfang, technische Anforderungen, Schutzmaßnahmen, Zeitplan und Kosten abgestimmt, bevor die Arbeiten fachgerecht ausgeführt werden.' },
  { q: 'Was passiert, wenn während der Sanierung weitere Schäden entdeckt werden?', a: 'Sollten zusätzliche Schäden oder unerwartete Befunde auftreten, informieren wir Sie transparent und stimmen die nächsten Schritte sowie mögliche Mehrkosten vorab mit Ihnen ab.' },
  { q: 'Warum sollte eine Sanierung nicht ohne Fachbetrieb erfolgen?', a: 'Gerade bei Bestandsgebäuden können versteckte Schäden, Feuchtigkeit, Schadstoffe oder statisch relevante Bauteile eine Rolle spielen. Ein Fachbetrieb sorgt für sichere Abläufe, fachgerechte Ausführung und klare Verantwortlichkeiten.' },
];

const reviews = [
  { quote: 'Die Schadstoffsanierung nach TRGS 519 lief absolut sicher und reibungslos — für unsere Mitarbeiter und den weiteren Betrieb.', name: 'A. Wegener', role: 'Facility Management · Stolberg' },
  { quote: 'Kontrollierter Rückbau, lückenlose Nachweise, saubere Freigabe. Genau so muss eine Sanierung laufen.', name: 'P. Krämer', role: 'Eigentümer · Aachen' },
  { quote: 'Energetische Revitalisierung im laufenden Betrieb — durchdacht geplant und termintreu umgesetzt.', name: 'J. Bauer', role: 'Verwaltung · Köln' },
];

const jsonLd = [
  breadcrumbSchema(breadcrumbs),
  serviceSchema({ name: 'Sanierung & Schadstoffsanierung', serviceType: 'Sanierung, Schadstoffsanierung', description, url: path }),
  faqSchema(faqs),
];
---

<Base title={title} description={description} canonicalPath={path} image="/img/sanierung-hero.webp" jsonLd={jsonLd}>
  <PageHero
    eyebrow="Leistung · Sanierung"
    title="Sanierung & Schadstoff-<br />rückbau nach TRGS 519"
    subtitle="Fachgerechter Rückbau, Schadstoffsanierung und energetische Revitalisierung — sicher für Mensch, Umwelt und Betrieb, lückenlos dokumentiert und freigegeben."
    image="/img/sanierung-hero.webp"
    breadcrumbs={breadcrumbs}
  />

  <section class="section">
    <div class="wrap">
      <span class="eyebrow" data-reveal>Sanierung vom Fachbetrieb</span>
      <p class="statement" style="margin-top:1.6rem" data-wordreveal>
        Wir sanieren in Aachen, Würselen und dem Rheinland — vom Asbestrückbau nach TRGS 519 bis zur energetischen Revitalisierung.
      </p>
      <p class="lead-text" data-reveal>
        Vom kontrollierten Rückbau über die Entkernung bis zur energetischen Sanierung: <strong>sicher geplant</strong>,
        sauber ausgeführt und mit <strong>lückenlosem Nachweis bis zur Freigabe</strong>. Schadstoffe sanieren wir
        fachgerecht nach TRGS 519 — zum Schutz Ihrer Mitarbeiter, der Umgebung und des weiteren Betriebs.
      </p>
    </div>
  </section>

  <!-- Leistungsumfang -->
  <section class="section grey">
    <div class="wrap">
      <div class="section-head" data-reveal>
        <span class="eyebrow">Leistungsumfang</span>
        <h2 class="tt">Sanieren — <span class="mute">sicher & nachweisbar.</span></h2>
      </div>
      <div class="feature-grid" data-reveal-group>
        {scope.map((s) => (
          <article class="feature-card"><h3>{s.t}</h3><p>{s.d}</p></article>
        ))}
      </div>
    </div>
  </section>

  <!-- #4 Branchen -->
  <Industries
    eyebrow="Branchen"
    title="Für wen wir"
    tail="sanieren & zurückbauen."
    items={[
      { label: 'Industrie & Gewerbe', desc: 'Rückbau und Sanierung von Produktions-, Lager- und Gewerbeflächen.' },
      { label: 'Bestandsimmobilien', desc: 'Energetische und bauliche Revitalisierung in die Jahre gekommener Gebäude.' },
      { label: 'Pharma & Labor', desc: 'Rückbau unter Hygiene- und Sicherheitsanforderungen, auch im sensiblen Umfeld.' },
      { label: 'Öffentliche Hand', desc: 'Sanierung und Schadstoffrückbau für öffentliche Gebäude und Liegenschaften.' },
      { label: 'Wohnungswirtschaft', desc: 'Bestands- und Schadstoffsanierung für Wohn- und Mehrfamilienobjekte.' },
      { label: 'Eigentümer & Verwalter', desc: 'Werterhalt durch fachgerechte Instandsetzung und Modernisierung.' },
    ]}
  />

  <!-- Showcase (Carousel) -->
  <Showcase
    variant="grey"
    eyebrow="Einblicke"
    title="So sieht Sanierung"
    tail="von Vonhoegen aus."
    intro="Vom sicheren Schadstoffrückbau bis zur energetischen Revitalisierung — ein Eindruck unserer Sanierungsprojekte. Wischen oder ziehen Sie für mehr."
    images={[
      { src: '/img/sanierung-schadstoff.webp', tag: 'Schadstoffsanierung', alt: 'Fachkräfte in Schutzanzügen bei der Schadstoffsanierung in abgeschottetem Bereich', caption: 'Schadstoffsanierung nach TRGS 519 — sicher abgeschottet' },
      { src: '/img/sanierung-rueckbau.webp', tag: 'Rückbau', alt: 'Kontrollierter Rückbau und Entkernung im Gebäudeinneren', caption: 'Kontrollierter Rückbau & Entkernung' },
      { src: '/img/sanierung-energetisch.webp', tag: 'Energetisch', alt: 'Energetische Sanierung mit Fassadendämmung', caption: 'Energetische Sanierung — Dämmung & Hülle' },
      { src: '/img/sanierung-bestand.webp', tag: 'Bestand', alt: 'Frisch saniertes Gebäudeinneres im Bestand', caption: 'Bestandssanierung — Werterhalt & Modernisierung' },
      { src: '/img/sanierung-entsorgung.webp', tag: 'Entsorgung', alt: 'Ordnungsgemäß getrennte Entsorgungscontainer auf der Baustelle', caption: 'Ordnungsgemäße Entsorgung mit lückenlosem Nachweis' },
    ]}
  />

  <!-- Detail-Bild + Vorteile -->
  <section class="section">
    <div class="wrap">
      <div class="split" data-reveal>
        <div class="media"><img src="/img/sanierung-schadstoff.webp" alt="Fachkräfte in Schutzanzügen bei der Schadstoffsanierung nach TRGS 519" loading="lazy" decoding="async" /></div>
        <div>
          <span class="eyebrow">Ihr Vorteil</span>
          <h2 class="tt" style="margin-top:1.2rem">Warum Eigentümer bei der Sanierung <span class="mute">auf Vonhoegen setzen.</span></h2>
          <div class="benefit-list" data-reveal-group>
            {benefits.map(([h, p]) => (
              <div class="benefit">
                <span class="ck">✓</span>
                <div><h3>{h}</h3><p>{p}</p></div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Kennzahlen -->
  <Stats
    variant="dark"
    items={[
      { value: 35, suffix: '+', label: 'Jahre Erfahrung im Bauwesen' },
      { value: 519, suffix: '', label: 'Sanierung nach TRGS 519' },
      { value: 100, suffix: ' %', label: 'lückenloser Nachweis bis zur Freigabe' },
      { value: 24, suffix: '/7', label: 'erreichbar für die Industrie' },
    ]}
    note="Beispielhafte Kennzahlen — werden nach Freigabe durch die echten Werte des Unternehmens ersetzt."
  />

  <!-- Ablauf -->
  <section class="section grey">
    <div class="wrap">
      <div class="section-head" data-reveal>
        <span class="eyebrow">Ablauf</span>
        <h2 class="tt">Von der Erfassung zur Freigabe — <span class="mute">in vier Schritten.</span></h2>
      </div>
      <div class="steps steps-4" data-reveal-group>
        {steps.map(([n, h, p]) => (
          <div class="step"><div class="no">{n}</div><div><h3>{h}</h3><p>{p}</p></div></div>
        ))}
      </div>
    </div>
  </section>

  <!-- #6 Vergleich -->
  <Comparison
    eyebrow="Im Vergleich"
    title="Sanierung vom Fachbetrieb"
    tail="oder ungeprüfter Rückbau?"
    guLabel="Vonhoegen — Sanierung & Nachweis"
    otherLabel="Ungeprüfter Rückbau"
    rows={[
      { label: 'Sicherheit', gu: 'TRGS 519, Abschottung & Schutzkonzept', other: 'Gefährdung von Mensch & Umwelt' },
      { label: 'Im laufenden Betrieb', gu: 'Abschnittsweise, mit Staubschutz', other: 'Betriebsunterbrechung nötig' },
      { label: 'Entsorgung', gu: 'Ordnungsgemäß, lückenlos belegt', other: 'Nachweise oft unvollständig' },
      { label: 'Freigabe', gu: 'Begleitet bis zur Freimessung', other: 'Risiko bei der Abnahme' },
      { label: 'Verantwortung', gu: 'Alles aus einer Hand', other: 'Schnittstellen zwischen Firmen' },
    ]}
  />

  <!-- Einsatzgebiet / Local SEO -->
  <section class="section grey">
    <div class="wrap">
      <div class="area-layout">
        <div class="area-intro" data-reveal>
          <span class="eyebrow">Einsatzgebiet</span>
          <h2 class="tt" style="margin-top:1.2rem">Ihr Sanierungs-Partner in <span class="mute">Aachen, NRW & dem Rheinland.</span></h2>
          <p class="lead-text" style="margin-top:1.4rem">
            Von unserem Standort in Würselen sind wir schnell in der gesamten <strong>Städteregion Aachen</strong> vor Ort —
            und realisieren Sanierungs- und Rückbauprojekte ebenso im weiteren Rheinland, von Düsseldorf bis Köln.
          </p>
        </div>
        <ul class="area-tags" data-reveal>
          <li>Würselen</li><li>Aachen</li><li>Städteregion Aachen</li><li>Eschweiler</li>
          <li>Stolberg</li><li>Herzogenrath</li><li>Alsdorf</li><li>Baesweiler</li>
          <li>Düren</li><li>Jülich</li><li>Düsseldorf</li><li>Köln</li>
          <li>Mönchengladbach</li><li>Neuss</li><li>Leverkusen</li><li>Rheinland</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- #5 Normen & Standards -->
  <Certifications
    eyebrow="Normen & Standards"
    title="Worauf Sie sich"
    tail="verlassen können."
    variant="default"
    items={[
      { label: 'TRGS 519', desc: 'Asbest- und Schadstoffsanierung fachgerecht nach TRGS 519.' },
      { label: 'Sicherheits- & Abschottungskonzept', desc: 'Schutz von Mitarbeitern, Umgebung und weiterem Betrieb.' },
      { label: 'Ordnungsgemäße Entsorgung', desc: 'Entsorgung mit lückenlosem, revisionssicherem Nachweis.' },
      { label: 'Freimessung & Freigabe', desc: 'Begleitung bis zur Freimessung und Freigabe durch zuständige Stellen.' },
      { label: 'Geschultes Personal', desc: 'Qualifiziertes, geschultes Personal für sichere Sanierung.' },
      { label: 'Geprüfte Partner & Eigenpersonal', desc: 'Eigene Fachkräfte und qualifizierte, langjährig geprüfte Nachunternehmer.' },
    ]}
    note="Beispielhafte Aufstellung — konkrete Zertifikate und Nachweise des Unternehmens werden nach Freigabe ergänzt."
  />

  <Reviews
    items={reviews}
    eyebrow="Referenzen & Stimmen"
    title="Sanierung, die"
    tail="sicher freigegeben wird."
    variant="grey"
  />

  <Faq items={faqs} title="Sanierung —" tail="häufige Fragen." />

  <!-- #7 Verwandte Leistungen -->
  <RelatedServices currentPath={path} variant="grey" />

  <CtaSection
    heading="Schadstoffe oder Sanierungsbedarf?"
    lead="Schildern Sie uns kurz Objekt und Umfang — wir melden uns innerhalb von 48 Stunden mit einer sicheren Einschätzung."
    image="/img/sanierung-hero.webp"
  />
</Base>
