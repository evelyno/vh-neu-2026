---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import CtaSection from '../components/CtaSection.astro';
import { breadcrumbSchema } from '../lib/schema';

const path = '/ueber-uns';
const title = 'Über uns — Bauunternehmen aus Würselen bei Aachen | Vonhoegen';
const description =
  'Die Vonhoegen Bauunternehmung aus Würselen: ein Bauunternehmen mit eigenem Stamm an Fachkräften, festem Ansprechpartner pro Projekt und einem Anspruch an Bauqualität, die Jahrzehnte hält.';

const breadcrumbs = [
  { label: 'Startseite', href: '/' },
  { label: 'Über uns', href: path },
];

const values = [
  ['Verlässlichkeit', 'Was wir zusagen, halten wir — Festpreis, Termin und Qualität. Lieber ehrlich früh sprechen als später überraschen.'],
  ['Substanz', 'Wir bauen für Jahrzehnte, nicht für das nächste Quartal. Gute Substanz zahlt sich über die gesamte Nutzungsdauer aus.'],
  ['Nähe', 'Ein fester Ansprechpartner pro Projekt, kurze Wege und regionale Verwurzelung in der Städteregion Aachen.'],
];

const qualities = [
  ['Rund um die Uhr erreichbar', 'Für Kunden der Industrie stehen wir rund um die Uhr telefonisch zur Verfügung — wenn es darauf ankommt, sind wir da.'],
  ['FDA-, GMP- & Brandschutz-geschult', 'Wir beschäftigen ausschließlich qualifiziertes und geschultes Personal. Unsere Mitarbeiter sind FDA-, GMP- und Brandschutz-geschult.'],
  ['Moderner Maschinen- & Fahrzeugpark', 'Unser Maschinen- und Fahrzeugpark ist stets auf dem neuesten Stand und unterliegt regelmäßigen jährlichen Prüfungen.'],
  ['Eigene Staubwandsysteme', 'Eigenentwickelte Staubwände (Staubboxen in jeder Größe) ermöglichen Arbeiten bei laufender Produktion — staubfrei und untermischungsfrei.'],
];

const jsonLd = [breadcrumbSchema(breadcrumbs)];
---

<Base title={title} description={description} canonicalPath={path} image="/img/ueber-uns-hero.webp" jsonLd={jsonLd}>
  <PageHero
    eyebrow="Über uns"
    title="Ein Partner, der bleibt —<br />vom ersten Termin an."
    subtitle="Die Vonhoegen Bauunternehmung steht für eine Bauweise, die an Jahrzehnten gemessen wird — mit eigenen Fachkräften und einem festen Ansprechpartner pro Projekt."
    image="/img/ueber-uns-hero.webp"
    breadcrumbs={breadcrumbs}
  />

  <!-- Intro / Haltung — Wort-Reveal wie auf den Leistungsseiten -->
  <section class="section">
    <div class="wrap">
      <span class="eyebrow" data-reveal>Unsere Haltung</span>
      <p class="statement" style="margin-top:1.6rem" data-wordreveal>
        Bauen mit Erfahrung lässt keine Wünsche offen.
      </p>
      <p class="lead-text" data-reveal>
        Als Bauunternehmen aus <strong>Würselen bei Aachen</strong> garantieren wir unseren Kunden ein
        <strong>Höchstmaß an Leistungsfähigkeit und Zuverlässigkeit</strong>. Alle Wünsche der Bauherren erfüllen wir
        mit unserem leistungsstarken Team — und langjährige Erfahrung mit verschiedensten Materialien und Techniken
        zeichnet unser Unternehmen aus.
      </p>
    </div>
  </section>

  <!-- Kompetenz & Ausstattung — als nummerierte Schritte -->
  <section class="section grey">
    <div class="wrap">
      <div class="section-head" data-reveal>
        <span class="eyebrow">Kompetenz & Ausstattung</span>
        <h2 class="tt">Worauf sich unsere Kunden <span class="mute">verlassen können.</span></h2>
      </div>
      <div class="steps steps-4" data-reveal-group>
        {qualities.map(([t, d], i) => (
          <div class="step">
            <div class="no">{String(i + 1).padStart(2, '0')}</div>
            <div><h3>{t}</h3><p>{d}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Werte -->
  <section class="section">
    <div class="wrap">
      <div class="section-head" data-reveal>
        <span class="eyebrow">Wofür wir stehen</span>
        <h2 class="tt">Drei Werte, <span class="mute">die jedes Projekt tragen.</span></h2>
      </div>
      <div class="feature-grid" data-reveal-group>
        {values.map(([t, d]) => (
          <article class="feature-card"><h3>{t}</h3><p>{d}</p></article>
        ))}
      </div>
    </div>
  </section>

  <!-- Partnerschaft Alemannia Aachen -->
  <section class="section grey">
    <div class="wrap">
      <div class="partner-callout" data-reveal>
        <div class="partner-logo">
          <img src="/img/alemannia-business-partner.png" alt="Alemannia Aachen Business Partner" width="150" height="188" loading="lazy" decoding="async" onerror="this.closest('.partner-logo').classList.add('is-empty')" />
          <span class="partner-logo-fallback">Alemannia Aachen<br />Business Partner</span>
        </div>
        <div class="partner-callout-text">
          <span class="eyebrow">Partnerschaft</span>
          <h2 class="tt" style="margin-top:1rem">Offizieller <span class="mute">Alemannia Aachen Business Partner.</span></h2>
          <p class="lead-text" style="margin-top:1.3rem">
            Wir sind in der Region nicht nur zuhause, wir engagieren uns hier — als offizieller Business Partner von
            Alemannia Aachen. Regionale Verbundenheit, die über die Baustelle hinausreicht.
          </p>
        </div>
      </div>
    </div>
  </section>

  <CtaSection />
</Base>
